# Database — SQLite for dev, PostgreSQL for production
# For Vercel (ephemeral SQLite, data resets on cold start):
# DATABASE_URL="file:/tmp/bus_jo.db"
# For production with Neon (recommended):
# DATABASE_URL="******host/dbname?sslmode=require"
DATABASE_URL="file:./server/prisma/dev.db"

# Session secret — change to a long random string in production
SESSION_SECRET="sat-bus-secret-change-in-production"

# Additional origins allowed for CORS (comma-separated), e.g. your custom domain
# ALLOWED_ORIGINS="https://myapp.com,https://www.myapp.com"
