{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/public" }
    },
    {
      "src": "server/src/vercel.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "server/prisma/**"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server/src/vercel.ts" },
    {
      "src": "/(.*\\.[a-z0-9]+)$",
      "dest": "/dist/public/$1"
    },
    { "src": "/(.*)", "dest": "/dist/public/index.html" }
  ]
}
