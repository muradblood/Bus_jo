{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "prisma db push --schema=server/prisma/schema.prisma --skip-generate --accept-data-loss && vite build",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/server"
    }
  ]
}
